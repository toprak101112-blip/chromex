{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "0.1.2",
  "minimum_chrome_version": "116",
  "key": "",
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "icons": {
    "16": "icons/codex-16.png",
    "32": "icons/codex-32.png",
    "48": "icons/codex-48.png",
    "128": "icons/codex-128.png"
  },
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "nativeMessaging"
  ],
  "optional_permissions": [
    "history",
    "tabs"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "__MSG_actionOpenSidePanel__",
    "default_icon": {
      "16": "icons/codex-16.png",
      "24": "icons/codex-24.png",
      "32": "icons/codex-32.png",
      "48": "icons/codex-48.png",
      "128": "icons/codex-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/codex-32.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "open-side-panel": {
      "description": "__MSG_commandOpenSidePanel__"
    },
    "open-popup-chat": {
      "description": "__MSG_commandOpenPopup__"
    }
  }
}
